# Banco de dados (Supabase)
DATABASE_URL=postgresql://user:password@host:5432/postgres
SUPABASE_URL=https://xxxx.supabase.co
SERVICE_ROLE_KEY=your-supabase-service-role-key

# Auth
JWT_SECRET=change-this-to-a-strong-random-secret
ADMIN_EMAIL=recepcao@nextaccess.com
ADMIN_SENHA=change-this-password

# Servidor
PORT=3000
BACKEND_URL=https://your-backend-url.com

# CORS — origens permitidas separadas por vírgula (use * para liberar tudo em dev)
CORS_ORIGINS=https://your-admin-web.com,https://your-other-origin.com

# Email (Gmail SMTP)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App mobile (deep link)
APP_URL=nextaccess://
